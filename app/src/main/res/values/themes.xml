<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme — Compose handles all colors/typography -->
    <style name="Theme.TrackFinz" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Splash screen theme using core-splashscreen -->
    <style name="Theme.TrackFinz.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#00BCD4</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.TrackFinz</item>
    </style>
</resources>
